{
  "manifest_version": 3,
  "name": "AccountHop for AWS",
  "version": "1.0.0",
  "description": "Automatically redirects AWS console URLs through your company's AWS access portal to open resources in the correct account context.",
  "permissions": [
    "webNavigation",
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.console.aws.amazon.com/*",
    "https://console.aws.amazon.com/*",
    "https://*.awsapps.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://*.console.aws.amazon.com/*",
        "https://console.aws.amazon.com/*"
      ],
      "js": ["shared/constants.js", "content/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.awsapps.com/*"
      ],
      "js": ["shared/constants.js", "content/portal-scraper.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
